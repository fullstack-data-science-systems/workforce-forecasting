    },
    {
      "name": "Error Scenarios",
      "item": [
        {
          "name": "POST /forecast - Invalid model (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/forecast", "host": ["{{base_url}}"], "path": ["forecast"] },
            "body": { "mode": "raw", "raw": "{\n  \"model_type\": \"bert\",\n  \"steps\": 12\n}" }
          },
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Returns 422 for invalid model', () => pm.response.to.have.status(422));"
            ], "type": "text/javascript" }}
          ]
        },
        {
          "name": "POST /forecast - Steps out of range (422)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/forecast", "host": ["{{base_url}}"], "path": ["forecast"] },
            "body": { "mode": "raw", "raw": "{\n  \"model_type\": \"lstm\",\n  \"steps\": 999\n}" }
          },
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Returns 422 for invalid steps', () => pm.response.to.have.status(422));"
            ], "type": "text/javascript" }}
          ]
        },
        {
          "name": "GET /models/invalid - 404",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/models/bert", "host": ["{{base_url}}"], "path": ["models", "bert"] }
          },
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Returns 404', () => pm.response.to.have.status(404));"
            ], "type": "text/javascript" }}
          ]
        }
